{
  "mcpServers": {
    "fullvision": {
      "type": "stdio",
      "command": "node",
      "args": ["${CLAUDE_PLUGIN_ROOT}/scripts/fv-mcp.mjs"]
    },
    "webflow": {
      "type": "http",
      "url": "https://mcp.webflow.com/sse"
    },
    "brevo": {
      "type": "http",
      "url": "https://mcp.brevo.com/mcp",
      "headers": {
        "api-key": "${BREVO_API_KEY}"
      }
    }
  }
}
